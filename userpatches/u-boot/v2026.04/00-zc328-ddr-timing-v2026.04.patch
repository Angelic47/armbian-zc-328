+
+/*
+ * ZC-328 does not provide an OP-TEE blob. U-Boot 2026.04 enables
+ * CONFIG_SPL_OPTEE_IMAGE for RK3288 SPL-FIT, which makes the common
+ * rockchip binman template require /fit/images/op-tee/tee-os and fail.
+ * Build a plain U-Boot FIT instead.
+ */
+&fit_template {
+	images {
+		/delete-node/ op-tee;
+	};
+
+	configurations {
+		@config-SEQ {
+			fit,firmware = "u-boot";
+		};
+	};
 };
